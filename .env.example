# Twilio dedicated subaccount + API key (automation auth)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_SECRET=your_api_key_secret
# Subaccount auth token — deploy authentication and signed M2/M3/swap probes
TWILIO_AUTH_TOKEN=your_subaccount_auth_token

# Destination phone number (E.164) that the line forwards to
YOUR_REAL_NUMBER=+15551234567
# Dedicated test-origination number (E.164), set after setup
TEST_NUMBER=
# Optional preferred area code for purchased numbers
DEFAULT_AREA_CODE=
# Unique lowercase identifier used to isolate this installation's number tags
INSTANCE_ID=replace-with-unique-id

# Deployed Function base URL, e.g. https://emergency-line-1234.twil.io
FUNCTION_URL=https://emergency-line-xxxx.twil.io
# Secret token gating the /health endpoint (random 32+ chars)
HEALTH_TOKEN=replace_with_long_random_token

# SMS is intentionally disabled until your sender registration is complete.
# Set to true only after registration and notification/STOP/START/HELP tests pass.
SMS_ENABLED=false
# Sender label included in automated missed-call and voicemail SMS notifications
MESSAGE_BRAND=Emergency Line
